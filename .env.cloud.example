# Runtime
NODE_ENV=production
PORT=4000

# Security (>= 32 chars)
JWT_SECRET=change_me_with_a_long_random_secret_32_chars_minimum

# Current app storage (temporary while migrating)
APP_DATA_DIR=/data
DB_FILE=/data/data.db
ARCHIVE_ROOT=/data/archives

# Target cloud architecture (to adopt during migration)
DATABASE_DRIVER=postgres
DATABASE_URL=postgres://user:password@host:5432/erp
REDIS_URL=redis://host:6379

# Traffic and body limits
API_RATE_MAX=1000
API_RATE_WINDOW_MS=60000
AUTH_RATE_MAX=20
AUTH_RATE_WINDOW_MS=900000
JSON_BODY_LIMIT=1mb

# Observability
SENTRY_DSN=
APPLICATIONINSIGHTS_CONNECTION_STRING=
